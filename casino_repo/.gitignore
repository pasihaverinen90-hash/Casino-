# Godot 4 .gitignore

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.translation
*.import

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Built files
*.apk
*.aab
*.ipa
*.pck
*.zip
*.tar.gz
builds/

# Editor settings (optional — remove if you want to share editor layout)
.godot/
*.uid
